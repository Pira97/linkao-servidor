<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Anula la config global de NuGet de esta máquina, que referencia una carpeta
    de Visual Studio inexistente ('...\Shared\NuGetPackages') y rompe el build (MSB4018).
    Con <clear/> eliminamos esos fallback folders heredados.
  -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
