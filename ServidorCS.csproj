<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <AssemblyName>ServidorCS</AssemblyName>
    <RootNamespace>ServidorCS</RootNamespace>
    <InvariantGlobalization>false</InvariantGlobalization>
  </PropertyGroup>

  <!-- CP1252 se implementa a mano en Network/Cp1252.cs: sin dependencias de NuGet. -->

  <!-- version.txt: versión de cliente requerida. Se copia junto al .exe para deployar a la VM. -->
  <ItemGroup>
    <None Update="version.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
